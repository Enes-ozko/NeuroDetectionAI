import os
import random
import numpy as np
import matplotlib.pyplot as plt

DIR_PROCESSED = r"C:\Users\munar\Desktop\NeuroDetectionAI\data\03_processed"

def visualiser_hasard():
    # On récupère tous les fichiers T1
    fichiers_t1 = [f for f in os.listdir(DIR_PROCESSED) if f.endswith('_t1.nii.gz_t1.npy') or f.endswith('_t1.npy')]

    if not fichiers_t1:
        print("Aucun fichier trouvé.")
        return

    # On en pioche un au hasard
    fichier_choisi = random.choice(fichiers_t1)
    fichier_mask = fichier_choisi.replace('_t1.npy', '_mask.npy')

    chemin_t1 = os.path.join(DIR_PROCESSED, fichier_choisi)
    chemin_mask = os.path.join(DIR_PROCESSED, fichier_mask)

    # Chargement des matrices NumPy
    img_t1 = np.load(chemin_t1)

    # Vérification si le masque existe (au cas où)
    if os.path.exists(chemin_mask):
        img_mask = np.load(chemin_mask)
    else:
        img_mask = np.zeros_like(img_t1)

    # Affichage
    plt.figure(figsize=(12, 6))

    # Image T1
    plt.subplot(1, 2, 1)
    plt.title(f"IRM T1 (Normalisée)\n{fichier_choisi}", fontsize=10)
    plt.imshow(img_t1, cmap='gray')
    plt.axis('off')

    # Masque
    plt.subplot(1, 2, 2)
    plt.title("Masque de Segmentation", fontsize=10)
    # On affiche l'IRM en fond, et le masque en rouge par-dessus avec de la transparence
    plt.imshow(img_t1, cmap='gray')
    plt.imshow(img_mask, cmap='Reds', alpha=0.5 * (img_mask > 0))
    plt.axis('off')

    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    visualiser_hasard()